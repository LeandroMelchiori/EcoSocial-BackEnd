# ===================================
# CONFIGURACIÓN DE BASE DE DATOS
# ===================================
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/foro_hub
SPRING_DATASOURCE_USERNAME=your_database_username
SPRING_DATASOURCE_PASSWORD=your_database_password

# ===================================
# SEGURIDAD JWT
# ===================================
# IMPORTANTE: Genera una clave secreta fuerte y única para tu aplicación
# Puedes generar una con: openssl rand -base64 32
API_SECURITY_SECRET=your_jwt_secret_key_change_this_in_production

# ===================================
# CONFIGURACIÓN DE ALMACENAMIENTO
# ===================================
# Opciones: local | minio
CATALOGO_STORAGE=local

# Configuración para almacenamiento local
CATALOGO_LOCAL_ROOT=uploads

# Configuración para MinIO (si usas minio)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET_NAME=forohub

# ===================================
# ACTUATOR Y MONITOREO
# ===================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never

# ===================================
# RATE LIMITING
# ===================================
APP_RATELIMIT_ENABLED=true
APP_RATELIMIT_LOGIN_MAX=50
APP_RATELIMIT_WRITE_MAX=200
APP_RATELIMIT_READ_MAX=800
APP_RATELIMIT_WINDOW_SECONDS=600

# ===================================
# NOTAS DE SEGURIDAD
# ===================================
# - NO subas este archivo con valores reales a repositorios públicos
# - Usa variables de entorno del sistema operativo en producción
# - Rota las claves JWT regularmente
# - Usa contraseñas fuertes para la base de datos
